{
  "expo": {
    "name": "DishGuru",
    "slug": "hello-world-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-store-icon.png",
    "scheme": "dishguru",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.dishguru.app",
      "buildNumber": "2",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow DishGuru to access your camera to take dish photos.",
        "LSApplicationQueriesSchemes": [
          "wolt",
          "tenbis"
        ]
      }
    },
    "android": {
      "package": "com.dishguru.app",
      "adaptiveIcon": {
        "backgroundColor": "#F9EDE4",
        "foregroundImage": "./assets/images/android-adaptive-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "203870bf-82dc-4143-96fa-9e2567761272"
      }
    }
  }
}
